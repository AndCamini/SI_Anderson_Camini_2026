@page "/transportadores"
@rendermode InteractiveServer
@using ProjetoSalaoDeBeleza.Models
@using ProjetoSalaoDeBeleza.Services
@inject TransportadoresService transportadoresService
@inject CidadesService cidadesService

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Transportadores</h3>
    <button class="btn btn-primary" @onclick="AbrirModalNovo">+ Cadastrar novo</button>
</div>

@if (!string.IsNullOrEmpty(mensagemErro))
{
    <div class="alert alert-danger alert-dismissible">
        @mensagemErro
        <button type="button" class="btn-close" @onclick="LimparMensagens"></button>
    </div>
}
@if (!string.IsNullOrEmpty(mensagemSucesso))
{
    <div class="alert alert-success alert-dismissible">
        @mensagemSucesso
        <button type="button" class="btn-close" @onclick="LimparMensagens"></button>
    </div>
}

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Cód</th>
            <th>Nome</th>
            <th>CPF</th>
            <th>CNPJ</th>
            <th>Email</th>
            <th>Telefone</th>
            <th>Cidade</th>
            <th>Ativo</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var t in listaTransportadores)
        {
            <tr>
                <td>@t.CodTransportador</td>
                <td>@t.Nome</td>
                <td>@t.CPF</td>
                <td>@t.CNPJ</td>
                <td>@t.Email</td>
                <td>@t.Telefone</td>
                <td>@t.oCidade?.Cidade</td>
                <td>@(t.Ativo ? "Sim" : "Não")</td>
                <td>
                    <button class="btn btn-warning btn-sm" @onclick="() => AbrirModalEditar(t)">Editar</button>
                    <button class="btn btn-danger btn-sm" @onclick="() => AbrirModalExcluir(t)">Excluir</button>
                </td>
            </tr>
        }
    </tbody>
</table>

@* Modal Cadastro/Edição *@
@if (modalFormAberto)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(transportadorAtual.CodTransportador == 0 ? "Novo Transportador" : "Editar Transportador")</h5>
                    <button type="button" class="btn-close" @onclick="FecharModalForm"></button>
                </div>
                <EditForm Model="@transportadorAtual" OnValidSubmit="Salvar" FormName="formTransportadores">
                    <DataAnnotationsValidator />
                    <div class="modal-body">
                        @if (!string.IsNullOrEmpty(mensagemErroModal))
                        {
                            <div class="alert alert-danger">@mensagemErroModal</div>
                        }
                        <div class="mb-3">
                            <label class="form-label">Nome</label>
                            <InputText @bind-Value="transportadorAtual.Nome" class="form-control" />
                            <ValidationMessage For="@(() => transportadorAtual.Nome)" />
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">CPF <small class="text-muted">(pessoa física)</small></label>
                                <InputText @bind-Value="transportadorAtual.CPF" class="form-control" maxlength="11" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">CNPJ <small class="text-muted">(pessoa jurídica)</small></label>
                                <InputText @bind-Value="transportadorAtual.CNPJ" class="form-control" maxlength="14" />
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Email</label>
                                <InputText @bind-Value="transportadorAtual.Email" class="form-control" />
                            </div>
                            <div class="col-md-3 mb-3">
                                <label class="form-label">Telefone</label>
                                <InputText @bind-Value="transportadorAtual.Telefone" class="form-control" maxlength="15" />
                            </div>
                            <div class="col-md-3 mb-3">
                                <label class="form-label">CEP</label>
                                <InputText @bind-Value="transportadorAtual.CEP" class="form-control" maxlength="8" />
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Rua</label>
                                <InputText @bind-Value="transportadorAtual.Rua" class="form-control" />
                            </div>
                            <div class="col-md-2 mb-3">
                                <label class="form-label">Número</label>
                                <InputText @bind-Value="transportadorAtual.Numero" class="form-control" maxlength="10" />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Complemento</label>
                                <InputText @bind-Value="transportadorAtual.Complemento" class="form-control" />
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Bairro</label>
                                <InputText @bind-Value="transportadorAtual.Bairro" class="form-control" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Cidade</label>
                                <InputSelect @bind-Value="transportadorAtual.CodCidade" class="form-select">
                                    <option value="0">Selecione...</option>
                                    @foreach (var cidade in listaCidades)
                                    {
                                        <option value="@cidade.CodCidade">@cidade.Cidade</option>
                                    }
                                </InputSelect>
                            </div>
                        </div>
                        <div class="mb-3 form-check">
                            <InputCheckbox @bind-Value="transportadorAtual.Ativo" class="form-check-input" id="ativoCheckTransp" />
                            <label class="form-check-label" for="ativoCheckTransp">Ativo</label>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="FecharModalForm">Cancelar</button>
                        <button type="submit" class="btn btn-primary">Salvar</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@* Modal Confirmação de Exclusão *@
@if (modalExcluirAberto && transportadorExcluir != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Confirmar Exclusão</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="FecharModalExcluir"></button>
                </div>
                <div class="modal-body">
                    <p class="text-danger fw-bold">Tem certeza que deseja excluir este transportador? Esta ação não pode ser desfeita.</p>
                    <table class="table table-sm table-bordered">
                        <tbody>
                            <tr><th>Código</th><td>@transportadorExcluir.CodTransportador</td></tr>
                            <tr><th>Nome</th><td>@transportadorExcluir.Nome</td></tr>
                            <tr><th>CPF</th><td>@transportadorExcluir.CPF</td></tr>
                            <tr><th>CNPJ</th><td>@transportadorExcluir.CNPJ</td></tr>
                            <tr><th>Email</th><td>@transportadorExcluir.Email</td></tr>
                            <tr><th>Telefone</th><td>@transportadorExcluir.Telefone</td></tr>
                            <tr><th>Cidade</th><td>@transportadorExcluir.oCidade?.Cidade</td></tr>
                            <tr><th>Ativo</th><td>@(transportadorExcluir.Ativo ? "Sim" : "Não")</td></tr>
                        </tbody>
                    </table>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="FecharModalExcluir">Cancelar</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmarExclusao">Excluir</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Transportadores> listaTransportadores = new();
    private List<Cidades> listaCidades = new();
    private Transportadores transportadorAtual = new();
    private Transportadores? transportadorExcluir;
    private bool modalFormAberto = false;
    private bool modalExcluirAberto = false;
    private string? mensagemErro;
    private string? mensagemSucesso;
    private string? mensagemErroModal;

    protected override async Task OnInitializedAsync()
    {
        listaCidades = await cidadesService.GetCidadesAsync();
        await CarregarTransportadores();
    }

    private async Task CarregarTransportadores()
    {
        listaTransportadores = await transportadoresService.GetTransportadoresAsync();
    }

    private void AbrirModalNovo()
    {
        transportadorAtual = new Transportadores();
        mensagemErroModal = null;
        modalFormAberto = true;
    }

    private void AbrirModalEditar(Transportadores t)
    {
        transportadorAtual = new Transportadores
        {
            CodTransportador = t.CodTransportador,
            Nome = t.Nome,
            CPF = t.CPF,
            CNPJ = t.CNPJ,
            Email = t.Email,
            Telefone = t.Telefone,
            CEP = t.CEP,
            Rua = t.Rua,
            Numero = t.Numero,
            Complemento = t.Complemento,
            Bairro = t.Bairro,
            CodCidade = t.CodCidade,
            Ativo = t.Ativo
        };
        mensagemErroModal = null;
        modalFormAberto = true;
    }

    private void FecharModalForm()
    {
        modalFormAberto = false;
        transportadorAtual = new Transportadores();
        mensagemErroModal = null;
    }

    private void AbrirModalExcluir(Transportadores t)
    {
        transportadorExcluir = t;
        modalExcluirAberto = true;
    }

    private void FecharModalExcluir()
    {
        modalExcluirAberto = false;
        transportadorExcluir = null;
    }

    private async Task Salvar()
    {
        LimparMensagens();
        try
        {
            if (transportadorAtual.CodTransportador == 0)
                await transportadoresService.AddTransportadorAsync(transportadorAtual);
            else
                await transportadoresService.UpdateTransportadorAsync(transportadorAtual);

            mensagemSucesso = "Transportador salvo com sucesso.";
            FecharModalForm();
            await CarregarTransportadores();
        }
        catch (Exception ex)
        {
            mensagemErroModal = ex.Message;
        }
    }

    private async Task ConfirmarExclusao()
    {
        if (transportadorExcluir == null) return;
        LimparMensagens();
        try
        {
            await transportadoresService.DeleteTransportadorAsync(transportadorExcluir.CodTransportador);
            mensagemSucesso = "Transportador excluído com sucesso.";
            FecharModalExcluir();
            await CarregarTransportadores();
        }
        catch (Exception ex)
        {
            mensagemErro = ex.Message;
            FecharModalExcluir();
        }
    }

    private void LimparMensagens()
    {
        mensagemErro = null;
        mensagemSucesso = null;
    }
}