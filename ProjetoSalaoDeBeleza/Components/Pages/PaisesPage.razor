@page "/paises"
@rendermode InteractiveServer
@using ProjetoSalaoDeBeleza.Models
@using ProjetoSalaoDeBeleza.Services
@inject PaisesService paisesService

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Países</h3>
    <button class="btn btn-primary" @onclick="AbrirModalNovo">+ Cadastrar novo</button>
</div>

@if (!string.IsNullOrEmpty(mensagemErro))
{
    <div class="alert alert-danger alert-dismissible">
        @mensagemErro
        <button type="button" class="btn-close" @onclick="LimparMensagens"></button>
    </div>
}
@if (!string.IsNullOrEmpty(mensagemSucesso))
{
    <div class="alert alert-success alert-dismissible">
        @mensagemSucesso
        <button type="button" class="btn-close" @onclick="LimparMensagens"></button>
    </div>
}

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Cód</th>
            <th>País</th>
            <th>Sigla</th>
            <th>DDI</th>
            <th>Moeda</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in listaPaises)
        {
            <tr>
                <td>@p.CodPais</td>
                <td>@p.Pais</td>
                <td>@p.Sigla</td>
                <td>@p.DDI</td>
                <td>@p.Moeda</td>
                <td>
                    <button class="btn btn-warning btn-sm" @onclick="() => AbrirModalEditar(p)">Editar</button>
                    <button class="btn btn-danger btn-sm" @onclick="() => AbrirModalExcluir(p)">Excluir</button>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (modalAberto)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(paisAtual.CodPais == 0 ? "Novo País" : "Editar País")</h5>
                    <button type="button" class="btn-close" @onclick="FecharModal"></button>
                </div>
                <EditForm Model="@paisAtual" OnValidSubmit="Salvar">
                    <DataAnnotationsValidator />
                    <div class="modal-body">
                        @if (!string.IsNullOrEmpty(mensagemErroModal))
                        {
                            <div class="alert alert-danger">@mensagemErroModal</div>
                        }
                        <div class="mb-3">
                            <label class="form-label">País</label>
                            <InputText @bind-Value="paisAtual.Pais" class="form-control" />
                            <ValidationMessage For="@(() => paisAtual.Pais)" />
                        </div>
                        <div class="row">
                            <div class="col-4 mb-3">
                                <label class="form-label">Sigla</label>
                                <InputText @bind-Value="paisAtual.Sigla" class="form-control" maxlength="3" />
                                <ValidationMessage For="@(() => paisAtual.Sigla)" />
                            </div>
                            <div class="col-4 mb-3">
                                <label class="form-label">DDI</label>
                                <InputText @bind-Value="paisAtual.DDI" class="form-control" maxlength="5" />
                                <ValidationMessage For="@(() => paisAtual.DDI)" />
                            </div>
                            <div class="col-4 mb-3">
                                <label class="form-label">Moeda</label>
                                <InputText @bind-Value="paisAtual.Moeda" class="form-control" maxlength="10" />
                                <ValidationMessage For="@(() => paisAtual.Moeda)" />
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="FecharModal">Cancelar</button>
                        <button type="submit" class="btn btn-primary">Salvar</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@if (modalExcluirAberto && paisExcluir != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Confirmar Exclusão</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="FecharModalExcluir"></button>
                </div>
                <div class="modal-body">
                    <p class="text-danger fw-bold">Tem certeza que deseja excluir este país? Esta ação não pode ser desfeita.</p>
                    <table class="table table-sm table-bordered">
                        <tbody>
                            <tr><th>Código</th><td>@paisExcluir.CodPais</td></tr>
                            <tr><th>País</th><td>@paisExcluir.Pais</td></tr>
                            <tr><th>Sigla</th><td>@paisExcluir.Sigla</td></tr>
                            <tr><th>DDI</th><td>@paisExcluir.DDI</td></tr>
                            <tr><th>Moeda</th><td>@paisExcluir.Moeda</td></tr>
                        </tbody>
                    </table>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="FecharModalExcluir">Cancelar</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmarExclusao">Excluir</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Paises> listaPaises = new();
    private Paises paisAtual = new();
    private bool modalAberto = false;
    private string? mensagemErro;
    private string? mensagemSucesso;
    private string? mensagemErroModal;

    protected override async Task OnInitializedAsync()
    {
        await CarregarPaises();
    }

    private async Task CarregarPaises()
    {
        listaPaises = await paisesService.GetPaisesAsync();
    }

    private void AbrirModalNovo()
    {
        paisAtual = new Paises();
        mensagemErroModal = null;
        modalAberto = true;
    }

    private void AbrirModalEditar(Paises p)
    {
        paisAtual = new Paises
        {
            CodPais = p.CodPais,
            Pais = p.Pais,
            Sigla = p.Sigla,
            DDI = p.DDI,
            Moeda = p.Moeda
        };
        mensagemErroModal = null;
        modalAberto = true;
    }

    private void FecharModal()
    {
        modalAberto = false;
        paisAtual = new Paises();
        mensagemErroModal = null;
    }

    private async Task Salvar()
    {
        LimparMensagens();
        try
        {
            if (paisAtual.CodPais == 0)
                await paisesService.AddPaisAsync(paisAtual);
            else
                await paisesService.UpdatePaisAsync(paisAtual);

            mensagemSucesso = "País salvo com sucesso.";
            FecharModal();
            await CarregarPaises();
        }
        catch (Exception ex)
        {
            mensagemErroModal = ex.Message;
        }
    }

    private Paises? paisExcluir;
    private bool modalExcluirAberto = false;

    private void AbrirModalExcluir(Paises p)
    {
        paisExcluir = p;
        modalExcluirAberto = true;
    }

    private void FecharModalExcluir()
    {
        modalExcluirAberto = false;
        paisExcluir = null;
    }

    private async Task ConfirmarExclusao()
    {
        if (paisExcluir == null) return;
        LimparMensagens();
        try
        {
            await paisesService.DeletePaisAsync(paisExcluir.CodPais);
            mensagemSucesso = "País excluído com sucesso.";
            FecharModalExcluir();
            await CarregarPaises();
        }
        catch (Exception ex)
        {
            mensagemErro = ex.Message;
            FecharModalExcluir();
        }
    }

    private void LimparMensagens()
    {
        mensagemErro = null;
        mensagemSucesso = null;
    }
}