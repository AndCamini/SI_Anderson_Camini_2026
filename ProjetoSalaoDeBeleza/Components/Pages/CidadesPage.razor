@page "/cidades"
@rendermode InteractiveServer
@using ProjetoSalaoDeBeleza.Models
@using ProjetoSalaoDeBeleza.Services
@inject CidadesService cidadesService
@inject EstadosService estadosService

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Cidades</h3>
    <button class="btn btn-primary" @onclick="AbrirModalNovo">+ Cadastrar novo</button>
</div>

@if (!string.IsNullOrEmpty(mensagemErro))
{
    <div class="alert alert-danger alert-dismissible">
        @mensagemErro
        <button type="button" class="btn-close" @onclick="LimparMensagens"></button>
    </div>
}
@if (!string.IsNullOrEmpty(mensagemSucesso))
{
    <div class="alert alert-success alert-dismissible">
        @mensagemSucesso
        <button type="button" class="btn-close" @onclick="LimparMensagens"></button>
    </div>
}

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Cód</th>
            <th>Cidade</th>
            <th>Estado</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var c in listaCidades)
        {
            <tr>
                <td>@c.CodCidade</td>
                <td>@c.Cidade</td>
                <td>@listaEstados.FirstOrDefault(e => e.CodEstado == c.CodEstado)?.Estado</td>
                <td>
                    <button class="btn btn-warning btn-sm" @onclick="() => AbrirModalEditar(c)">Editar</button>
                    <button class="btn btn-danger btn-sm" @onclick="() => AbrirModalExcluir(c)">Excluir</button>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (modalAberto)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(cidadeAtual.CodCidade == 0 ? "Nova Cidade" : "Editar Cidade")</h5>
                    <button type="button" class="btn-close" @onclick="FecharModal"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(mensagemErroModal))
                    {
                        <div class="alert alert-danger">@mensagemErroModal</div>
                    }
                    <div class="mb-3">
                        <label class="form-label">Cidade</label>
                        <InputText @bind-Value="cidadeAtual.Cidade" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Estado</label>
                        <InputSelect @bind-Value="cidadeAtual.CodEstado" class="form-select">
                            <option value="0">Selecione...</option>
                            @foreach (var estado in listaEstados)
                            {
                                <option value="@estado.CodEstado">@estado.Estado</option>
                            }
                        </InputSelect>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="FecharModal">Cancelar</button>
                    <button type="button" class="btn btn-primary" @onclick="Salvar">Salvar</button>
                </div>
            </div>
        </div>
    </div>
}

@if (modalExcluirAberto && cidadeExcluir != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Confirmar Exclusão</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="FecharModalExcluir"></button>
                </div>
                <div class="modal-body">
                    <p class="text-danger fw-bold">Tem certeza que deseja excluir esta cidade? Esta ação não pode ser desfeita.</p>
                    <table class="table table-sm table-bordered">
                        <tbody>
                            <tr><th>Código</th><td>@cidadeExcluir.CodCidade</td></tr>
                            <tr><th>Cidade</th><td>@cidadeExcluir.Cidade</td></tr>
                            <tr><th>Estado</th><td>@listaEstados.FirstOrDefault(e => e.CodEstado == cidadeExcluir.CodEstado)?.Estado</td></tr>
                        </tbody>
                    </table>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="FecharModalExcluir">Cancelar</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmarExclusao">Excluir</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Cidades> listaCidades = new();
    private List<Estados> listaEstados = new();
    private Cidades cidadeAtual = new();
    private bool modalAberto = false;
    private string? mensagemErro;
    private string? mensagemSucesso;
    private string? mensagemErroModal;

    protected override async Task OnInitializedAsync()
    {
        await CarregarDados();
    }

    private async Task CarregarDados()
    {
        listaCidades = await cidadesService.GetCidadesAsync();
        listaEstados = await estadosService.GetEstadosAsync();
    }

    private void AbrirModalNovo()
    {
        cidadeAtual = new Cidades();
        mensagemErroModal = null;
        modalAberto = true;
    }

    private void AbrirModalEditar(Cidades c)
    {
        cidadeAtual = new Cidades
        {
            CodCidade = c.CodCidade,
            Cidade = c.Cidade,
            CodEstado = c.CodEstado
        };
        mensagemErroModal = null;
        modalAberto = true;
    }

    private void FecharModal()
    {
        modalAberto = false;
        cidadeAtual = new Cidades();
        mensagemErroModal = null;
    }

    private async Task Salvar()
    {
        LimparMensagens();
        try
        {
            if (cidadeAtual.CodCidade == 0)
                await cidadesService.AddCidadeAsync(cidadeAtual);
            else
                await cidadesService.UpdateCidadeAsync(cidadeAtual);

            mensagemSucesso = "Cidade salva com sucesso.";
            FecharModal();
            await CarregarDados();
        }
        catch (Exception ex)
        {
            mensagemErroModal = ex.Message;
        }
    }

    private Cidades? cidadeExcluir;
    private bool modalExcluirAberto = false;

    private void AbrirModalExcluir(Cidades c)
    {
        cidadeExcluir = c;
        modalExcluirAberto = true;
    }

    private void FecharModalExcluir()
    {
        modalExcluirAberto = false;
        cidadeExcluir = null;
    }

    private async Task ConfirmarExclusao()
    {
        if (cidadeExcluir == null) return;
        LimparMensagens();
        try
        {
            await cidadesService.DeleteCidadeAsync(cidadeExcluir.CodCidade);
            mensagemSucesso = "Cidade excluída com sucesso.";
            FecharModalExcluir();
            await CarregarDados();
        }
        catch (Exception ex)
        {
            mensagemErro = ex.Message;
            FecharModalExcluir();
        }
    }

    private void LimparMensagens()
    {
        mensagemErro = null;
        mensagemSucesso = null;
    }
}