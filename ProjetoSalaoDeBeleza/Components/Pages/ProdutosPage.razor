@page "/produtos"
@rendermode InteractiveServer
@using ProjetoSalaoDeBeleza.Models
@using ProjetoSalaoDeBeleza.Services
@inject ProdutosService produtosService
@inject CategoriasService categoriasService

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Produtos</h3>
    <button class="btn btn-primary" @onclick="AbrirModalNovo">+ Cadastrar novo</button>
</div>

@if (!string.IsNullOrEmpty(mensagemErro))
{
    <div class="alert alert-danger alert-dismissible">
        @mensagemErro
        <button type="button" class="btn-close" @onclick="LimparMensagens"></button>
    </div>
}
@if (!string.IsNullOrEmpty(mensagemSucesso))
{
    <div class="alert alert-success alert-dismissible">
        @mensagemSucesso
        <button type="button" class="btn-close" @onclick="LimparMensagens"></button>
    </div>
}

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Cód</th>
            <th>Nome</th>
            <th>Categoria</th>
            <th>Custo</th>
            <th>Venda</th>
            <th>Estoque</th>
            <th>Unidade</th>
            <th>Ativo</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in listaProdutos)
        {
            <tr>
                <td>@p.CodProduto</td>
                <td>@p.Produto</td>
                <td>@p.oCategoria?.Categoria</td>
                <td>@p.PrecoCusto.ToString("C2")</td>
                <td>@p.PrecoVenda.ToString("C2")</td>
                <td>@p.Estoque</td>
                <td>@p.UnidadeMedida</td>
                <td>@(p.Ativo ? "Sim" : "Não")</td>
                <td>
                    <button class="btn btn-warning btn-sm" @onclick="() => AbrirModalEditar(p)">Editar</button>
                    <button class="btn btn-danger btn-sm" @onclick="() => AbrirModalExcluir(p)">Excluir</button>
                </td>
            </tr>
        }
    </tbody>
</table>

@* Modal Cadastro/Edição *@
@if (modalFormAberto)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(produtoAtual.CodProduto == 0 ? "Novo Produto" : "Editar Produto")</h5>
                    <button type="button" class="btn-close" @onclick="FecharModalForm"></button>
                </div>
                <EditForm Model="@produtoAtual" OnValidSubmit="Salvar">
                    <DataAnnotationsValidator />
                    <div class="modal-body">
                        @if (!string.IsNullOrEmpty(mensagemErroModal))
                        {
                            <div class="alert alert-danger">@mensagemErroModal</div>
                        }
                        <div class="mb-3">
                            <label class="form-label">Nome</label>
                            <InputText @bind-Value="produtoAtual.Produto" class="form-control" />
                            <ValidationMessage For="@(() => produtoAtual.Produto)" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Descrição</label>
                            <InputTextArea @bind-Value="produtoAtual.Descricao" class="form-control" rows="3" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Categoria</label>
                            <InputSelect @bind-Value="produtoAtual.CodCategoria" class="form-select">
                                <option value="0">Selecione...</option>
                                @foreach (var cat in listaCategorias)
                                {
                                    <option value="@cat.CodCategoria">@cat.Categoria</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Preço de Custo</label>
                                <InputNumber @bind-Value="produtoAtual.PrecoCusto" class="form-control" />
                                <ValidationMessage For="@(() => produtoAtual.PrecoCusto)" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Preço de Venda</label>
                                <InputNumber @bind-Value="produtoAtual.PrecoVenda" class="form-control" />
                                <ValidationMessage For="@(() => produtoAtual.PrecoVenda)" />
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Estoque</label>
                                <InputNumber @bind-Value="produtoAtual.Estoque" class="form-control" />
                                <ValidationMessage For="@(() => produtoAtual.Estoque)" />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Unidade de Medida</label>
                                <InputText @bind-Value="produtoAtual.UnidadeMedida" class="form-control" maxlength="10" />
                                <ValidationMessage For="@(() => produtoAtual.UnidadeMedida)" />
                            </div>
                        </div>
                        <div class="mb-3 form-check">
                            <InputCheckbox @bind-Value="produtoAtual.Ativo" class="form-check-input" id="ativoCheckProd" />
                            <label class="form-check-label" for="ativoCheckProd">Ativo</label>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="FecharModalForm">Cancelar</button>
                        <button type="submit" class="btn btn-primary">Salvar</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@* Modal Confirmação de Exclusão *@
@if (modalExcluirAberto && produtoExcluir != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Confirmar Exclusão</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="FecharModalExcluir"></button>
                </div>
                <div class="modal-body">
                    <p class="text-danger fw-bold">Tem certeza que deseja excluir este produto? Esta ação não pode ser desfeita.</p>
                    <table class="table table-sm table-bordered">
                        <tbody>
                            <tr><th>Código</th><td>@produtoExcluir.CodProduto</td></tr>
                            <tr><th>Nome</th><td>@produtoExcluir.Produto</td></tr>
                            <tr><th>Categoria</th><td>@produtoExcluir.oCategoria?.Categoria</td></tr>
                            <tr><th>Descrição</th><td>@produtoExcluir.Descricao</td></tr>
                            <tr><th>Preço de Custo</th><td>@produtoExcluir.PrecoCusto.ToString("C2")</td></tr>
                            <tr><th>Preço de Venda</th><td>@produtoExcluir.PrecoVenda.ToString("C2")</td></tr>
                            <tr><th>Estoque</th><td>@produtoExcluir.Estoque</td></tr>
                            <tr><th>Unidade</th><td>@produtoExcluir.UnidadeMedida</td></tr>
                            <tr><th>Ativo</th><td>@(produtoExcluir.Ativo ? "Sim" : "Não")</td></tr>
                        </tbody>
                    </table>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="FecharModalExcluir">Cancelar</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmarExclusao">Excluir</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Produtos> listaProdutos = new();
    private List<Categorias> listaCategorias = new();
    private Produtos produtoAtual = new();
    private Produtos? produtoExcluir;
    private bool modalFormAberto = false;
    private bool modalExcluirAberto = false;
    private string? mensagemErro;
    private string? mensagemSucesso;
    private string? mensagemErroModal;

    protected override async Task OnInitializedAsync()
    {
        listaCategorias = await categoriasService.GetCategoriasAsync();
        await CarregarProdutos();
    }

    private async Task CarregarProdutos()
    {
        listaProdutos = await produtosService.GetProdutosAsync();
    }

    private void AbrirModalNovo()
    {
        produtoAtual = new Produtos();
        mensagemErroModal = null;
        modalFormAberto = true;
    }

    private void AbrirModalEditar(Produtos p)
    {
        produtoAtual = new Produtos
        {
            CodProduto = p.CodProduto,
            Produto = p.Produto,
            Descricao = p.Descricao,
            PrecoCusto = p.PrecoCusto,
            PrecoVenda = p.PrecoVenda,
            Estoque = p.Estoque,
            UnidadeMedida = p.UnidadeMedida,
            Ativo = p.Ativo,
            CodCategoria = p.CodCategoria
        };
        mensagemErroModal = null;
        modalFormAberto = true;
    }

    private void FecharModalForm()
    {
        modalFormAberto = false;
        produtoAtual = new Produtos();
        mensagemErroModal = null;
    }

    private void AbrirModalExcluir(Produtos p)
    {
        produtoExcluir = p;
        modalExcluirAberto = true;
    }

    private void FecharModalExcluir()
    {
        modalExcluirAberto = false;
        produtoExcluir = null;
    }

    private async Task Salvar()
    {
        LimparMensagens();
        try
        {
            if (produtoAtual.CodProduto == 0)
                await produtosService.AddProdutoAsync(produtoAtual);
            else
                await produtosService.UpdateProdutoAsync(produtoAtual);

            mensagemSucesso = "Produto salvo com sucesso.";
            FecharModalForm();
            await CarregarProdutos();
        }
        catch (Exception ex)
        {
            mensagemErroModal = ex.Message;
        }
    }

    private async Task ConfirmarExclusao()
    {
        if (produtoExcluir == null) return;
        LimparMensagens();
        try
        {
            await produtosService.DeleteProdutoAsync(produtoExcluir.CodProduto);
            mensagemSucesso = "Produto excluído com sucesso.";
            FecharModalExcluir();
            await CarregarProdutos();
        }
        catch (Exception ex)
        {
            mensagemErro = ex.Message;
            FecharModalExcluir();
        }
    }

    private void LimparMensagens()
    {
        mensagemErro = null;
        mensagemSucesso = null;
    }
}