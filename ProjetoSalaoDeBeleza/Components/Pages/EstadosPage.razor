@if (modalAberto)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(estadoAtual.CodEstado == 0 ? "Novo Estado" : "Editar Estado")</h5>
                    <button type="button" class="btn-close" @onclick="FecharModal"></button>
                </div>
                <EditForm Model="@estadoAtual" OnValidSubmit="Salvar">
                    <DataAnnotationsValidator />
                    <div class="modal-body">
                        @if (!string.IsNullOrEmpty(mensagemErroModal))
                        {
                            <div class="alert alert-danger">@mensagemErroModal</div>
                        }
                        <div class="mb-3">
                            <label class="form-label">Estado</label>
                            <InputText @bind-Value="estadoAtual.Estado" class="form-control" />
                            <ValidationMessage For="@(() => estadoAtual.Estado)" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">UF</label>
                            <InputText @bind-Value="estadoAtual.UF" class="form-control" style="max-width: 80px;" maxlength="2" />
                            <ValidationMessage For="@(() => estadoAtual.UF)" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">País</label>
                            <InputSelect @bind-Value="estadoAtual.CodPais" class="form-select">
                                <option value="0">Selecione...</option>
                                @foreach (var pais in listaPaises)
                                {
                                    <option value="@pais.CodPais">@pais.Pais</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => estadoAtual.CodPais)" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="FecharModal">Cancelar</button>
                        <button type="submit" class="btn btn-primary">Salvar</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private List<Estados> listaEstados = new();
    private List<Paises> listaPaises = new();
    private Estados estadoAtual = new();
    private bool modalAberto = false;
    private string? mensagemErro;
    private string? mensagemSucesso;
    private string? mensagemErroModal;

    protected override async Task OnInitializedAsync()
    {
        await CarregarDados();
    }

    private async Task CarregarDados()
    {
        listaEstados = await estadosService.GetEstadosAsync();
        listaPaises = await paisesService.GetPaisesAsync();
    }

    private void AbrirModalNovo()
    {
        estadoAtual = new Estados();
        mensagemErroModal = null;
        modalAberto = true;
    }

    private void AbrirModalEditar(Estados e)
    {
        estadoAtual = new Estados
        {
            CodEstado = e.CodEstado,
            Estado = e.Estado,
            UF = e.UF,
            CodPais = e.CodPais
        };
        mensagemErroModal = null;
        modalAberto = true;
    }

    private void FecharModal()
    {
        modalAberto = false;
        estadoAtual = new Estados();
        mensagemErroModal = null;
    }

    private async Task Salvar()
    {
        LimparMensagens();
        try
        {
            if (estadoAtual.CodEstado == 0)
                await estadosService.AddEstadoAsync(estadoAtual);
            else
                await estadosService.UpdateEstadoAsync(estadoAtual);

            mensagemSucesso = "Estado salvo com sucesso.";
            FecharModal();
            await CarregarDados();
        }
        catch (Exception ex)
        {
            mensagemErroModal = ex.Message;
        }
    }

    private async Task Excluir(int id)
    {
        LimparMensagens();
        try
        {
            await estadosService.DeleteEstadoAsync(id);
            mensagemSucesso = "Estado excluído com sucesso.";
            await CarregarDados();
        }
        catch (Exception ex)
        {
            mensagemErro = ex.Message;
        }
    }

    private void LimparMensagens()
    {
        mensagemErro = null;
        mensagemSucesso = null;
    }
}