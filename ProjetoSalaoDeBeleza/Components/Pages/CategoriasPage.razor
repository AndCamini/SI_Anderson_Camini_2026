@page "/categorias"
@rendermode InteractiveServer
@using ProjetoSalaoDeBeleza.Models
@using ProjetoSalaoDeBeleza.Services
@inject CategoriasService categoriasService

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Categorias</h3>
    <button class="btn btn-primary" @onclick="AbrirModalNovo">+ Cadastrar novo</button>
</div>

@if (!string.IsNullOrEmpty(mensagemErro))
{
    <div class="alert alert-danger alert-dismissible">
        @mensagemErro
        <button type="button" class="btn-close" @onclick="LimparMensagens"></button>
    </div>
}
@if (!string.IsNullOrEmpty(mensagemSucesso))
{
    <div class="alert alert-success alert-dismissible">
        @mensagemSucesso
        <button type="button" class="btn-close" @onclick="LimparMensagens"></button>
    </div>
}

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Cód</th>
            <th>Nome</th>
            <th>Ativo</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var c in listaCategorias)
        {
            <tr>
                <td>@c.CodCategoria</td>
                <td>@c.Categoria</td>
                <td>@(c.Ativo ? "Sim" : "Não")</td>
                <td>
                    <button class="btn btn-warning btn-sm" @onclick="() => AbrirModalEditar(c)">Editar</button>
                    <button class="btn btn-danger btn-sm" @onclick="() => Excluir(c.CodCategoria)">Excluir</button>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (modalAberto)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(categoriaAtual.CodCategoria == 0 ? "Nova Categoria" : "Editar Categoria")</h5>
                    <button type="button" class="btn-close" @onclick="FecharModal"></button>
                </div>
                <EditForm Model="@categoriaAtual" OnValidSubmit="Salvar">
                    <DataAnnotationsValidator />
                    <div class="modal-body">
                        @if (!string.IsNullOrEmpty(mensagemErroModal))
                        {
                            <div class="alert alert-danger">@mensagemErroModal</div>
                        }
                        <div class="mb-3">
                            <label class="form-label">Nome</label>
                            <InputText @bind-Value="categoriaAtual.Categoria" class="form-control" />
                            <ValidationMessage For="@(() => categoriaAtual.Categoria)" />
                        </div>
                        <div class="mb-3 form-check">
                            <InputCheckbox @bind-Value="categoriaAtual.Ativo" class="form-check-input" id="ativoCheck" />
                            <label class="form-check-label" for="ativoCheck">Ativo</label>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="FecharModal">Cancelar</button>
                        <button type="submit" class="btn btn-primary">Salvar</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private List<Categorias> listaCategorias = new();
    private Categorias categoriaAtual = new();
    private bool modalAberto = false;
    private string? mensagemErro;
    private string? mensagemSucesso;
    private string? mensagemErroModal;

    protected override async Task OnInitializedAsync()
    {
        await CarregarCategorias();
    }

    private async Task CarregarCategorias()
    {
        listaCategorias = await categoriasService.GetCategoriasAsync();
    }

    private void AbrirModalNovo()
    {
        categoriaAtual = new Categorias();
        mensagemErroModal = null;
        modalAberto = true;
    }

    private void AbrirModalEditar(Categorias c)
    {
        categoriaAtual = new Categorias
        {
            CodCategoria = c.CodCategoria,
            Categoria = c.Categoria,
            Ativo = c.Ativo
        };
        mensagemErroModal = null;
        modalAberto = true;
    }

    private void FecharModal()
    {
        modalAberto = false;
        categoriaAtual = new Categorias();
        mensagemErroModal = null;
    }

    private async Task Salvar()
    {
        LimparMensagens();
        try
        {
            if (categoriaAtual.CodCategoria == 0)
                await categoriasService.AddCategoriaAsync(categoriaAtual);
            else
                await categoriasService.UpdateCategoriaAsync(categoriaAtual);

            mensagemSucesso = "Categoria salva com sucesso.";
            FecharModal();
            await CarregarCategorias();
        }
        catch (Exception ex)
        {
            mensagemErroModal = ex.Message;
        }
    }

    private async Task Excluir(int id)
    {
        LimparMensagens();
        try
        {
            await categoriasService.DeleteCategoriaAsync(id);
            mensagemSucesso = "Categoria excluída com sucesso.";
            await CarregarCategorias();
        }
        catch (Exception ex)
        {
            mensagemErro = ex.Message;
        }
    }

    private void LimparMensagens()
    {
        mensagemErro = null;
        mensagemSucesso = null;
    }
}