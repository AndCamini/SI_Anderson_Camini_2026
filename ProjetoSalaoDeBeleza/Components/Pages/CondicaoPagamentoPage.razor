@page "/condicoes-pagamento"
@rendermode InteractiveServer
@using ProjetoSalaoDeBeleza.Models
@using ProjetoSalaoDeBeleza.Services
@inject CondicaoPagamentoService condicaoPagamentoService

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Condições de Pagamento</h3>
    <button class="btn btn-primary" @onclick="AbrirModalNovo">+ Cadastrar novo</button>
</div>

@if (!string.IsNullOrEmpty(mensagemErro))
{
    <div class="alert alert-danger alert-dismissible">
        @mensagemErro
        <button type="button" class="btn-close" @onclick="LimparMensagens"></button>
    </div>
}
@if (!string.IsNullOrEmpty(mensagemSucesso))
{
    <div class="alert alert-success alert-dismissible">
        @mensagemSucesso
        <button type="button" class="btn-close" @onclick="LimparMensagens"></button>
    </div>
}

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Cód</th>
            <th>Descrição</th>
            <th>Parcelas</th>
            <th>Juros (%)</th>
            <th>Multa (%)</th>
            <th>Desconto (%)</th>
            <th>Ativo</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var c in listaCondicoes)
        {
            <tr>
                <td>@c.CodCondicao</td>
                <td>@c.Descricao</td>
                <td>@c.NumeroParcelas</td>
                <td>@c.Juros.ToString("F2")</td>
                <td>@c.Multa.ToString("F2")</td>
                <td>@c.Desconto.ToString("F2")</td>
                <td>@(c.Ativo ? "Sim" : "Não")</td>
                <td>
                    <button class="btn btn-warning btn-sm" @onclick="() => AbrirModalEditar(c)">Editar</button>
                    <button class="btn btn-danger btn-sm" @onclick="() => AbrirModalExcluir(c)">Excluir</button>
                </td>
            </tr>
        }
    </tbody>
</table>

@* Modal Cadastro/Edição *@
@if (modalFormAberto)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(condicaoAtual.CodCondicao == 0 ? "Nova Condição de Pagamento" : "Editar Condição de Pagamento")</h5>
                    <button type="button" class="btn-close" @onclick="FecharModalForm"></button>
                </div>
                <EditForm Model="@condicaoAtual" OnValidSubmit="Salvar">
                    <DataAnnotationsValidator />
                    <div class="modal-body">
                        @if (!string.IsNullOrEmpty(mensagemErroModal))
                        {
                            <div class="alert alert-danger">@mensagemErroModal</div>
                        }
                        <div class="mb-3">
                            <label class="form-label">Descrição</label>
                            <InputText @bind-Value="condicaoAtual.Descricao" class="form-control" />
                            <ValidationMessage For="@(() => condicaoAtual.Descricao)" />
                        </div>
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Nº de Parcelas</label>
                                <InputNumber @bind-Value="condicaoAtual.NumeroParcelas" class="form-control" />
                                <ValidationMessage For="@(() => condicaoAtual.NumeroParcelas)" />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">1ª Parcela (dias)</label>
                                <InputNumber @bind-Value="condicaoAtual.PrimeiraParcela" class="form-control" />
                                <ValidationMessage For="@(() => condicaoAtual.PrimeiraParcela)" />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Entre Parcelas (dias)</label>
                                <InputNumber @bind-Value="condicaoAtual.EntreParcelas" class="form-control" />
                                <ValidationMessage For="@(() => condicaoAtual.EntreParcelas)" />
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Juros (%)</label>
                                <InputNumber @bind-Value="condicaoAtual.Juros" class="form-control" />
                                <ValidationMessage For="@(() => condicaoAtual.Juros)" />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Multa (%)</label>
                                <InputNumber @bind-Value="condicaoAtual.Multa" class="form-control" />
                                <ValidationMessage For="@(() => condicaoAtual.Multa)" />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Desconto (%)</label>
                                <InputNumber @bind-Value="condicaoAtual.Desconto" class="form-control" />
                                <ValidationMessage For="@(() => condicaoAtual.Desconto)" />
                            </div>
                        </div>

                        <hr />
                        <h6>Parcelas</h6>

                        @{
                            var totalPercentual = condicaoAtual.Parcelas.Sum(p => p.Percentual);
                            var totalClass = totalPercentual == 100 ? "text-success" : "text-danger";
                            var parcelasOk = condicaoAtual.Parcelas.Count == condicaoAtual.NumeroParcelas;
                        }

                        @if (condicaoAtual.Parcelas.Count > 0 && !parcelasOk)
                        {
                            <div class="alert alert-warning py-1">
                                Você informou @condicaoAtual.NumeroParcelas parcela(s), mas cadastrou @condicaoAtual.Parcelas.Count.
                            </div>
                        }

                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Nº</th>
                                    <th>Dias</th>
                                    <th>% Parcela</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var parcela in condicaoAtual.Parcelas)
                                {
                                    var diasInvalidos = parcela.Dias < 0;
                                    var percentualInvalido = parcela.Percentual <= 0;
                                    <tr>
                                        <td>@parcela.Numero</td>
                                        <td>
                                            <InputNumber @bind-Value="parcela.Dias"
                                                         class="@($"form-control form-control-sm {(diasInvalidos ? "is-invalid" : "")}")" />
                                            @if (diasInvalidos)
                                            {
                                                <div class="invalid-feedback">Dias não pode ser negativo.</div>
                                            }
                                        </td>
                                        <td>
                                            <InputNumber @bind-Value="parcela.Percentual"
                                                         class="@($"form-control form-control-sm {(percentualInvalido ? "is-invalid" : "")}")" />
                                            @if (percentualInvalido)
                                            {
                                                <div class="invalid-feedback">Percentual deve ser maior que 0%.</div>
                                            }
                                        </td>
                                        <td>
                                            <button type="button" class="btn btn-danger btn-sm"
                                                    @onclick="() => RemoverParcela(parcela)">
                                                🗑
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>

                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="AdicionarParcela">
                                + Adicionar parcela
                            </button>
                            <span class="@totalClass fw-bold">
                                Total: @totalPercentual.ToString("F2")%
                                @if (totalPercentual == 100)
                                {
                                    <span> ✔</span>
                                }
                                else
                                {
                                    <span> (faltam @((100 - totalPercentual).ToString("F2"))%)</span>
                                }
                            </span>
                        </div>

                        <div class="mb-3 form-check">
                            <InputCheckbox @bind-Value="condicaoAtual.Ativo" class="form-check-input" id="ativoCheckCond" />
                            <label class="form-check-label" for="ativoCheckCond">Ativo</label>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="FecharModalForm">Cancelar</button>
                        <button type="submit" class="btn btn-primary">Salvar</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@* Modal Confirmação de Exclusão *@
@if (modalExcluirAberto && condicaoExcluir != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Confirmar Exclusão</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="FecharModalExcluir"></button>
                </div>
                <div class="modal-body">
                    <p class="text-danger fw-bold">Tem certeza que deseja excluir esta condição? Esta ação não pode ser desfeita.</p>
                    <table class="table table-sm table-bordered">
                        <tbody>
                            <tr><th>Código</th><td>@condicaoExcluir.CodCondicao</td></tr>
                            <tr><th>Descrição</th><td>@condicaoExcluir.Descricao</td></tr>
                            <tr><th>Parcelas</th><td>@condicaoExcluir.NumeroParcelas</td></tr>
                            <tr><th>1ª Parcela (dias)</th><td>@condicaoExcluir.PrimeiraParcela</td></tr>
                            <tr><th>Entre Parcelas (dias)</th><td>@condicaoExcluir.EntreParcelas</td></tr>
                            <tr><th>Juros</th><td>@condicaoExcluir.Juros.ToString("F2")%</td></tr>
                            <tr><th>Multa</th><td>@condicaoExcluir.Multa.ToString("F2")%</td></tr>
                            <tr><th>Desconto</th><td>@condicaoExcluir.Desconto.ToString("F2")%</td></tr>
                            <tr><th>Ativo</th><td>@(condicaoExcluir.Ativo ? "Sim" : "Não")</td></tr>
                        </tbody>
                    </table>
                    @if (condicaoExcluir.Parcelas.Any())
                    {
                        <h6 class="mt-3">Parcelas vinculadas</h6>
                        <table class="table table-sm table-bordered">
                            <thead>
                                <tr><th>Nº</th><th>Dias</th><th>%</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var p in condicaoExcluir.Parcelas.OrderBy(p => p.Numero))
                                {
                                    <tr>
                                        <td>@p.Numero</td>
                                        <td>@p.Dias</td>
                                        <td>@p.Percentual.ToString("F2")%</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="FecharModalExcluir">Cancelar</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmarExclusao">Excluir</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<CondicaoPagamento> listaCondicoes = new();
    private CondicaoPagamento condicaoAtual = new();
    private CondicaoPagamento? condicaoExcluir;
    private bool modalFormAberto = false;
    private bool modalExcluirAberto = false;
    private string? mensagemErro;
    private string? mensagemSucesso;
    private string? mensagemErroModal;

    protected override async Task OnInitializedAsync()
    {
        await CarregarCondicoes();
    }

    private async Task CarregarCondicoes()
    {
        listaCondicoes = await condicaoPagamentoService.GetCondicoesPagamentoAsync();
    }

    private void AbrirModalNovo()
    {
        condicaoAtual = new CondicaoPagamento();
        mensagemErroModal = null;
        modalFormAberto = true;
    }

    private void AbrirModalEditar(CondicaoPagamento c)
    {
        condicaoAtual = new CondicaoPagamento
        {
            CodCondicao = c.CodCondicao,
            Descricao = c.Descricao,
            NumeroParcelas = c.NumeroParcelas,
            PrimeiraParcela = c.PrimeiraParcela,
            EntreParcelas = c.EntreParcelas,
            Juros = c.Juros,
            Multa = c.Multa,
            Desconto = c.Desconto,
            Ativo = c.Ativo,
            Parcelas = c.Parcelas.Select(p => new CondicaoPagamentoParcela
            {
                CodParcela = p.CodParcela,
                CodCondicao = p.CodCondicao,
                Numero = p.Numero,
                Dias = p.Dias,
                Percentual = p.Percentual
            }).ToList()
        };
        mensagemErroModal = null;
        modalFormAberto = true;
    }

    private void FecharModalForm()
    {
        modalFormAberto = false;
        condicaoAtual = new CondicaoPagamento();
        mensagemErroModal = null;
    }

    private void AbrirModalExcluir(CondicaoPagamento c)
    {
        condicaoExcluir = c;
        modalExcluirAberto = true;
    }

    private void FecharModalExcluir()
    {
        modalExcluirAberto = false;
        condicaoExcluir = null;
    }

    private void AdicionarParcela()
    {
        condicaoAtual.Parcelas.Add(new CondicaoPagamentoParcela
        {
            Numero = condicaoAtual.Parcelas.Count + 1,
            Dias = 0,
            Percentual = 0
        });
    }

    private void RemoverParcela(CondicaoPagamentoParcela parcela)
    {
        condicaoAtual.Parcelas.Remove(parcela);
        for (int i = 0; i < condicaoAtual.Parcelas.Count; i++)
            condicaoAtual.Parcelas[i].Numero = i + 1;
    }

    private async Task Salvar()
    {
        LimparMensagens();
        try
        {
            if (condicaoAtual.CodCondicao == 0)
                await condicaoPagamentoService.AddCondicaoAsync(condicaoAtual);
            else
                await condicaoPagamentoService.UpdateCondicaoAsync(condicaoAtual);

            mensagemSucesso = "Condição de pagamento salva com sucesso.";
            FecharModalForm();
            await CarregarCondicoes();
        }
        catch (Exception ex)
        {
            mensagemErroModal = ex.Message;
        }
    }

    private async Task ConfirmarExclusao()
    {
        if (condicaoExcluir == null) return;
        LimparMensagens();
        try
        {
            await condicaoPagamentoService.DeleteCondicaoAsync(condicaoExcluir.CodCondicao);
            mensagemSucesso = "Condição de pagamento excluída com sucesso.";
            FecharModalExcluir();
            await CarregarCondicoes();
        }
        catch (Exception ex)
        {
            mensagemErro = ex.Message;
            FecharModalExcluir();
        }
    }

    private void LimparMensagens()
    {
        mensagemErro = null;
        mensagemSucesso = null;
    }
}